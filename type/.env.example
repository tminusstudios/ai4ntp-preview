# Local secrets for tools/ scripts (e.g. tools/reconcile-referrals.mjs).
# Copy this file to .env and fill in the real values. .env NEVER commits or deploys
# (it is in .vercelignore). Do not paste secrets into chat or share this file.

# --- Supabase (required for the referral reconciler write) ---
# Supabase dashboard -> Project Settings -> API -> service_role (secret).
# Same value as the Vercel SUPABASE_SERVICE_ROLE_KEY (which pulls back empty because it is Sensitive).
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# --- Zoom Server-to-Server OAuth (only needed for `--zoom`, the CSV-free attendance pull) ---
# Same app + values as the Vercel Zoom env vars. Zoom Marketplace -> your S2S app -> App Credentials.
# The app also needs the "report:read:admin" scope (add it, then Activate/Reactivate the app).
ZOOM_ACCOUNT_ID=REPLACE
ZOOM_CLIENT_ID=REPLACE
ZOOM_CLIENT_SECRET=REPLACE
# Numeric webinar id for the session you are reconciling (Zoom webinar Details page -> "Webinar ID").
# 006 was 87317768498. Update this each session, or omit to auto-detect the newest past webinar.
ZOOM_WEBINAR_ID=REPLACE
